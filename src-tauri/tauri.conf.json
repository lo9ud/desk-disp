{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "desk-disp",
  "version": "0.1.0",
  "identifier": "com.adamd.desk-disp",
  "build": {
    "beforeDevCommand": "pnpm tauri:predev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm tauri:prebuild",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }

  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/dark/32x32.png",
      "icons/dark/128x128.png",
      "icons/dark/128x128@2x.png",
      "icons/dark/icon.icns",
      "icons/dark/icon.ico"
    ]
  }
}
